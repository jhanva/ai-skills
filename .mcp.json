{
  "mcpServers": {
    "aseprite": {
      "command": "${MCP_PYTHON:-python}",
      "args": [
        "./plugins/aseprite-codex/scripts/aseprite_mcp.py"
      ]
    },
    "godot": {
      "command": "${MCP_PYTHON:-python}",
      "args": [
        "./plugins/godot-codex/scripts/godot_mcp.py"
      ]
    },
    "pixellab": {
      "type": "http",
      "url": "https://api.pixellab.ai/mcp",
      "headers": {
        "Authorization": "Bearer ${PIXELLAB_API_TOKEN}"
      }
    }
  }
}
